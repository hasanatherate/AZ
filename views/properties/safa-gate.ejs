        <!-- Additional Property Information -->
        <div class="property-content">
            <section class="property-section">
                <h2>1 Bedroom</h2>
                <ul class="highlights-list">
                    <li>Area: 769 sq.ft</li>
                    <li>Premium Safa Park & Sea view</li>
                    <li>Price: AED 2,309,000</li>
                </ul>
            </section>

            <section class="property-section">
                <h2>2 Bedroom</h2>
                <ul class="highlights-list">
                    <li>Area: 1,174 sq.ft</li>
                    <li>Butterfly layout</li>
                    <li>Sheikh Zayed Road view</li>
                    <li>Price: AED 3,124,000</li>
                </ul>
            </section>

            <!-- CTA -->
            <section class="property-cta">
                <h3>Interested in Safa Gate?</h3>
                <p>Contact our real estate consultants for brochure, availability, and booking support.</p>
                <a href="#contact" class="btn btn-primary popup-trigger">Get More Info</a>
            </section>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
