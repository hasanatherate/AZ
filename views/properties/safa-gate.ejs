<%- include('../partials/header') %>

<!-- Property Detail Section -->
<section class="property-detail">
    <div class="container">
        <!-- Property Header -->
        <div class="property-header">
            <h1>Safa Gate</h1>
        </div>

        <!-- Main Property Section -->
        <div class="property-main-section">
            <!-- Left Side - Property Image -->
            <div class="property-image-container">
                <img src="https://res.cloudinary.com/dfcaqxkii/image/upload/q_auto/f_auto/v1776096952/safa_gate_v6samp.jpg" alt="Safa Gate" class="property-hero-image">
            </div>

            <!-- Right Side - Property Details -->
            <div class="property-details">
                <div class="property-section">
                    <h2>Overview</h2>
                    <p>Safa Gate presents a safest investment opportunity in a premium location near Safa Park and Sheikh Zayed Road, with strong long-term value and excellent demand potential.</p>

                    <h2>Project Highlights</h2>
